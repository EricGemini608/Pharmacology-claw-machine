        .score-box { background-color: #27ae60; padding: 5px 12px; border-radius: 10px; font-weight: bold; border: 2px solid #fff; }
        .remain-box { background-color: #2980b9; padding: 5px 12px; border-radius: 10px; font-weight: bold; border: 2px solid #fff; }
        #gameCanvas { background-color: #2c3e50; border: 10px solid #f1c40f; border-radius: 15px; box-shadow: 0 5px 25px rgba(0,0,0,0.7); max-width: 95vw; max-height: 60vh; }
        .controls-container { display: flex; gap: 15px; margin-top: 10px; width: 90%; max-width: 400px; justify-content: center; }
        .touch-btn {
            background-color: #e67e22; color: white; border: 3px solid #d35400; border-radius: 12px;
            padding: 12px 20px; font-size: 18px; font-weight: bold; cursor: pointer;
            box-shadow: 0 4px #ba4a00; user-select: none; flex: 1; text-align: center;
        }
        .touch-btn:active { box-shadow: 0 1px #ba4a00; transform: translateY(3px); background-color: #d35400; }
        .action-btn { background-color: #e74c3c; border-color: #c0392b; box-shadow: 0 4px #962d22; }
        .action-btn:active { background-color: #c0392b; box-shadow: 0 1px #962d22; }
        
        /* 彈出視窗 UI */
        .quiz-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.9); display: none; justify-content: center; align-items: center; z-index: 100; }
        .quiz-container { background-color: #ffffff; color: #333; padding: 20px; border-radius: 20px; max-width: 450px; width: 85%; box-shadow: 0 5px 30px rgba(0,0,0,0.5); border-top: 12px solid #ccc; max-height: 85vh; overflow-y: auto; }
        .quiz-header { font-size: 14px; font-weight: bold; margin-bottom: 5px; padding: 4px 10px; border-radius: 5px; display: inline-block; }
        .quiz-question { font-size: 17px; font-weight: bold; margin: 10px 0; line-height: 1.4; color: #2c3e50; }
        .option-btn { display: block; width: 100%; padding: 10px; margin: 6px 0; font-size: 15px; text-align: left; background-color: #f8f9fa; border: 2px solid #dee2e6; border-radius: 10px; cursor: pointer; color: #495057; }
        .result-box { margin-top: 10px; padding: 12px; border-radius: 10px; display: none; line-height: 1.5; font-size: 14px; }
        .result-success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .result-wrong { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
        .next-btn { display: none; width: 100%; padding: 12px; margin-top: 12px; font-size: 16px; background-color: #2ecc71; color: white; border: none; border-radius: 10px; cursor: pointer; font-weight: bold; }
        .game-over-panel { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; color: #333; padding: 30px; border-radius: 25px; text-align: center; box-shadow: 0 0 40px rgba(0,0,0,0.8); display: none; z-index: 200; width: 75%; max-width: 350px; }
        .final-score { font-size: 40px; color: #e74c3c; font-weight: bold; margin: 15px 0; }
        .final-msg { font-size: 18px; font-weight: bold; line-height: 1.5; color: #2c3e50; }
        .rules { font-size: 12px; color: #bdc3c7; margin-top: 5px; text-align: center; }
    </style>
