    <script>
        let audioCtx = null;
        function initAudio() { if (!audioCtx) { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } }
        function playDropSound() {
            if (!audioCtx) return;
            let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain(); osc.connect(gain); gain.connect(audioCtx.destination);
            osc.type = "sawtooth"; osc.frequency.setValueAtTime(300, audioCtx.currentTime); osc.frequency.exponentialRampToValueAtTime(80, audioCtx.currentTime + 0.2);
            gain.gain.setValueAtTime(0.15, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);
            osc.start(); osc.stop(audioCtx.currentTime + 0.2);
        }
        function playCatchSound() {
            if (!audioCtx) return;
            let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain(); osc.connect(gain); gain.connect(audioCtx.destination);
            osc.type = "sine"; osc.frequency.setValueAtTime(523.25, audioCtx.currentTime); osc.frequency.setValueAtTime(783.99, audioCtx.currentTime + 0.08); 
            gain.gain.setValueAtTime(0.2, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.25);
            osc.start(); osc.stop(audioCtx.currentTime + 0.25);
        }
        function playMissSound() {
            if (!audioCtx) return;
            let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain(); osc.connect(gain); gain.connect(audioCtx.destination);
            osc.type = "triangle"; osc.frequency.setValueAtTime(130.81, audioCtx.currentTime); 
            gain.gain.setValueAtTime(0.2, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.15);
            osc.start(); osc.stop(audioCtx.currentTime + 0.15);
        }
        
        // 點擊封面直接開始遊戲，封面會淡出消失
        function startGame() { 
            initAudio(); 
            const startScreen = document.getElementById("startScreen"); 
            startScreen.classList.add("hidden"); 
            setTimeout(() => { startScreen.style.display = "none"; }, 400); 
        }

        const quizBank = {
            white: [
                { q: "請問有關抗高血壓藥物 Sodium Nitroprusside 的敘述下列何者錯誤？", opts: ["副作用有姿位性低血壓、反射性心跳過速", "嚴重低血壓危象的急救", "這個藥物對光敏感，宜避光使用"], ans: 1, note: "解析：應該是高血壓危害（危象）的急救。" },
                { q: "請問有關抗高血壓藥物 Hydralazine 的敘述下列何者錯誤？", opts: ["高劑量可能引起可逆性類紅斑性狼瘡症狀", "因擴張血管使得反射性心跳增加", "常與利尿劑或交感神經Alpha接受器阻斷劑併用"], ans: 2, note: "解析：常與利尿劑或交感神經Beta接受器阻斷劑併用。" },
                { q: "請問有關抗高血壓藥物 Minoxidil 的敘述下列何者正確？", opts: ["會活化血管平滑肌細胞的鉀離子通道，使細胞內鉀離子外流，使膜電位過極化，降低血管興奮性", "本產品對光過敏，宜避光使用", "會造成少毛症"], ans: 0, note: "解析：B選項的藥物是Sodium Nitroprusside；C應為多毛症。" },
                { q: "請問有關抗高血壓藥物 Diazoxide 的敘述，下列何者正確？", opts: ["短期治療嚴重的急性低血壓", "血糖會上升", "血糖會下降"], ans: 1, note: "解析：A應為短期治療嚴重的急性高血壓；C為血糖會上升。" },
                { q: "下列何種抗高血壓藥物不是血管擴張劑？", opts: ["Prazosin", "Hydralazine", "Minoxidil"], ans: 0, note: "解析：Prazosin是交感神經α1接受器阻斷劑，而非直接作用的血管擴張劑。" },
                { q: "請問有關抗高血壓藥物 Hydralazine 的敘述，下列何者錯誤？", opts: ["會導致頭痛、噁心、心律不整與末梢神經症狀", "因擴張血管會使反射性心跳增加", "低劑量可能引起可逆性類紅斑性狼瘡"], ans: 2, note: "解析：應該是高劑量長期使用可能引起可逆性類紅斑性狼瘡。" },
                { q: "請問有關抗高血壓藥物 Prazosin 的敘述，下列何者正確？", opts: ["選擇性抑制alpha1接受器，擴張周邊小動脈血管平滑肌，降低末梢血管阻力", "改善低血壓，治療良性前列腺肥大(BPH)", "會在血液中釋放一氧化氮（NO）"], ans: 0, note: "解析：B應為改善高血壓；C釋放NO的藥物是Sodium Nitroprusside。" },
                { q: "請問有關抗高血壓藥物 Sodium Nitroprusside 的敘述，下列何者正確？", opts: ["在血液中釋出一氧化氮(NO)，活化鳥苷酸環化酶使cGMP增加放鬆平滑肌", "擴張動脈可降低後負荷，擴張靜脈可降低靜脈回流與前負荷", "以上皆是"], ans: 2, note: "解析：以上皆是。該藥具有平衡擴張動靜脈之特性。" },
                { q: "請問有關抗高血壓藥物-血管擴張劑的敘述下列何者錯誤？", opts: ["直接作用於血管骨骼肌，使血管擴張", "部分藥物擴張小動脈血管的作用會使周邊阻力降低，產生降血壓效果", "部分擴張小靜脈血管，藉引起靜脈回流與減少心輸出量來降血壓"], ans: 0, note: "解析：血管擴張劑是直接作用於血管「平滑肌」，而不是骨骼肌。" },
                { q: "請問有關抗高血壓藥物-血管擴張劑 Minoxidil 的敘述下列何者正確？", opts: ["目前已被製成外用製劑，用於改善落髮與禿頭", "會造成多毛症", "以上皆是"], ans: 2, note: "解析：以上皆是。其多毛症副作用被商品化開發成生髮水（如落建）。" }
            ],
            blue: [
                { q: "請問下列哪一藥物並非血管緊縮素轉換酶抑制劑（ACEI)？", opts: ["Captopril", "Lisinopril", "lrbesartan"], ans: 2, note: "解析：Irbesartan字尾為-sartan，是血管緊縮素受體阻斷劑（ARBs）。" },
                { q: "請問下列何者藥物是抗高血壓第一線藥物中的B受體阻斷劑？", opts: ["Metoprolol", "Atenolol", "以上皆是"], ans: 2, note: "解析：以上皆是。字尾-olol者多為Beta阻斷劑。" },
                { q: "請問下列何者藥物是抗高血壓第一線藥物中的鈣離子通道阻斷劑（CCBs）？", opts: ["Nifedipine", "Amlodipine", "以上皆是"], ans: 2, note: "解析：以上皆是。字尾-dipine為二氫吡啶類CCB血管選擇性降壓藥。" },
                { q: "請問有關抗高血壓第一線藥物中的利尿劑及副作用的配對，下列何者錯誤？", opts: ["Chlorothiazide-高尿酸血症", "Furosemide-高尿酸血症", "Spironolactone-高尿酸血症"], ans: 2, note: "解析：Spironolactone是保鉀利尿劑，特異副作用是抗雄性素導致的男性女乳症。" },
                { q: "請問有關抗高血壓第一線藥物中的B受體阻斷劑的敘述，下列何者正確？", opts: ["降低心跳速率", "抑制腎素（renin）分泌", "以上皆是"], ans: 2, note: "解析：以上皆是。阻斷Beta1受體可減慢心速並抑制腎臟釋放腎素。" },
                { q: "請問有關抗高血壓第一線藥物中的利尿劑的敘述下列何者錯誤？", opts: ["促進鈉、水排出，使血量及心輸出量降低", "離子跟水分會流失", "會抑制腎素（ranin）分泌"], ans: 2, note: "解析：利尿劑會排鈉排水，血容積減少反而會反射性刺激腎素分泌；會抑制腎素的是B受體阻斷劑。" }
            ],
            red: [
                { q: "請問有關抗高血壓第一線藥物中的B受體阻斷劑的敘述下列何者正確？", opts: ["會導致氣管痙攣", "會導致心搏過快", "手足會發熱"], ans: 0, note: "解析：非選擇性Beta阻斷劑會阻斷Beta2引起支氣管痙攣；B應為心搏過慢；C為手足冰冷。" },
                { q: "請問有關抗高血壓第一線藥物中的血管緊縮素轉換酶抑制劑的敘述下列何者錯誤？", opts: ["抑制血管緊縮素轉換酶使血管緊縮素II無法合成", "會咳嗽、口乾、味覺降低", "會造成氣管痙攣"], ans: 2, note: "解析：會造成氣管痙攣的是B受體阻斷劑。ACEI引發乾咳是因為緩激肽（Bradykinin）堆積。" },
                { q: "有關抗高血壓第一線藥物的分類與機轉的配對，下列何者正確？", opts: ["利尿劑-促進鈉、水排出，使血量及心輸出量降低", "B受體阻斷劑-抑制腎素（renin）分泌", "以上皆是"], ans: 2, note: "解析：以上皆是。" },
                { q: "請問有關抗高血壓第一線藥物中的B受體阻斷劑的敘述下列何者正確？", opts: ["需要注意會掩蓋低血糖的症狀", "心搏會過快", "不會做惡夢"], ans: 0, note: "解析：Beta阻斷劑會抑制低血糖引發的交感神經警訊（如心悸、發抖）；此外脂溶性高者易導致做惡夢。" }
            ]
