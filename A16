            display: flex; justify-content: center; align-items: center;
            z-index: 9999;
            transition: opacity 0.4s ease;
        }
        /* 替代實體圖片的 SVG 向量繪圖樣式 */
        .svg-cover {
            width: 90%; max-width: 400px; height: auto;
            cursor: pointer;
            filter: drop-shadow(0px 10px 25px rgba(0,0,0,0.6));
            transition: transform 0.2s ease;
        }
        .svg-cover:hover { transform: scale(1.02); }
        #startScreen.hidden { opacity: 0; pointer-events: none; }
        
        /* 遊戲機台本身的樣式 */
        body {
            margin: 0; background-color: #1a252f;
            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;
